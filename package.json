{
  "name": "spring",
  "version": "1.0.0",
  "description": "A one-page, two-column Jekyll theme that pairs beautifully styled content with contextual media.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "start": "npm-run-all --parallel watch serve",
    "serve": "bundle exec jekyll serve --livereload",
    "lint": "eslint \"_js/**/*.js\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/connor-baer/spring.git"
  },
  "keywords": [
    "connor",
    "bär",
    "designer",
    "traveller",
    "code",
    "jekyll",
    "developer",
    "spring"
  ],
  "author": "Connor Bär",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/connor-baer/spring/issues"
  },
  "homepage": "https://connor-baer.github.io/spring/",
  "dependencies": {
    "normalize.css": "^8.0.1",
    "open-color": "^1.9.1",
    "smooth-scroll": "^16.1.3"
  },
  "devDependencies": {
    "chokidar": "^3.6.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.15.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.81.0"
  }
}
